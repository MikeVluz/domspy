# Supabase PostgreSQL connection string (Transaction pooler)
DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Super Admin (used by seed script)
SUPER_ADMIN_EMAIL="admin@domspy.com"
SUPER_ADMIN_PASSWORD="change-this-password"
SUPER_ADMIN_NAME="Super Admin"

# Cloudflare bypass header (configure matching WAF rule in Cloudflare)
DOMSPY_CRAWL_KEY="your-secret-key-here"
